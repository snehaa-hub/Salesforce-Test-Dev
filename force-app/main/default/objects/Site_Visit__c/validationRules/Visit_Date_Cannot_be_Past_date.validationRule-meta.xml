<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Visit_Date_Cannot_be_Past_date</fullName>
    <active>true</active>
    <errorConditionFormula>ISNEW() &amp;&amp; TEXT(Created_From__c) != $Label.Created_From_API &amp;&amp; Visit_Date_Time__c &lt; NOW()</errorConditionFormula>
    <errorMessage>&quot;Visit Date/Time&quot; cannot be past date/time.</errorMessage>
</ValidationRule>

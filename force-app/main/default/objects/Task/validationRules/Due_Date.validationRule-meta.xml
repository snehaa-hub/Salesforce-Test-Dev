<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Due_Date</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
  $Profile.Name = &quot;Platform Profile&quot;,
  NOT(ISBLANK( ActivityDate )), ISCHANGED(ActivityDate ) 
)</errorConditionFormula>
    <errorMessage>You are not allowed to set Due Date</errorMessage>
</ValidationRule>

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Read_only_rule_for_Qualified</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    $Profile.Name = &quot;Platform Profile&quot;,
    ISCHANGED(Status__c),
    TEXT(PRIORVALUE(Status__c)) = &quot;Closed&quot;
)</errorConditionFormula>
    <errorMessage>Once Status : Closed and Reason for Closed: Qualified cannot Edit the field</errorMessage>
</ValidationRule>

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Reason_When_Closed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Closed&quot;),
    ISPICKVAL(Reason_for_Closed__c, &quot;&quot;)
)</errorConditionFormula>
    <errorMessage>Please select a Reason for Closure when the Status is Closed.</errorMessage>
</ValidationRule>
